  },
  "modules": [
    {
      "code": "core_intelligence",
      "name": "Unified Intelligence Layer",
      "capabilities": [
        "unified_crm",
        "shared_customer_database",
        "cross_os_activity_tracking",
        "global_analytics_pipeline",
        "unified_notifications",
        "unified_task_engine"
      ]
    },
    {
      "code": "crm",
      "name": "CRM Hub",
      "capabilities": [
        "single_customer_profile",
        "global_relationship_timeline",
        "task_ownership_and_sla"
      ]
