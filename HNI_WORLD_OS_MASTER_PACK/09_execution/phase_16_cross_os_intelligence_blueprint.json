  ],
  "cross_os_connections": [
    { "source": "LEGALNOMICS", "target": "CRM", "sync_mode": "bidirectional" },
    { "source": "EDUNOMICS", "target": "CRM", "sync_mode": "bidirectional" },
    { "source": "AIRNOMICS", "target": "CRM", "sync_mode": "bidirectional" },
